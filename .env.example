# Postgres
POSTGRES_PASSWORD=changeme
DATABASE_URL=postgresql://frigg:changeme@localhost:5432/frigg

# Baïkal CardDAV — only used once, at first startup, to seed the initial
# admin's own carddav_accounts row (backward compat for pre-auth deployments).
# Ignored after that; every user (including the admin) connects their Baïkal
# account afterwards via Settings in the app.
CARDDAV_URL=https://baikal.skords.de/dav.php
CARDDAV_USERNAME=sven
CARDDAV_PASSWORD=changeme

# Internal service URL (web → api)
API_URL=http://localhost:3001

# Optional: restrict CORS origin in api
WEB_ORIGIN=http://localhost:3000

# First-run only: creates the initial admin account if no admin exists yet.
# Forced to change password on first login. Safe to leave set permanently —
# bootstrap is a no-op once an admin exists.
INITIAL_ADMIN_EMAIL=admin@example.com
INITIAL_ADMIN_PASSWORD=changeme

# 32 bytes, base64-encoded — encrypts stored CardDAV account passwords at rest.
# Generate with: openssl rand -base64 32
CREDENTIALS_ENCRYPTION_KEY=changeme
